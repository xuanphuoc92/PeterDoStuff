@using PeterDoStuff.Tools.Graphics

<line x1="@Model.Start.X" y1="@Model.Start.Y"
      x2="@Model.End.X" y2="@Model.End.Y"
      stroke="@Model.Style.StrokeColor"
      stroke-opacity="@Model.Style.StrokeOpacity"
      stroke-width="@Model.Style.StrokeWidth" />

@code {
    [Parameter]
    public Line Model { get; set; }
}
