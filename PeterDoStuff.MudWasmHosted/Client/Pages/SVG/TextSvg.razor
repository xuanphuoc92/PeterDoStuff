@using PeterDoStuff.Tools.Graphics

<text font-size="@Model.FontSize"
      text-anchor="@Model.Anchor"
      fill="@Model.Style.FillColor"
      fill-opacity="@Model.Style.FillOpacity"
      stroke="@Model.Style.StrokeColor" stroke-dasharray="@Model.Style.StrokeDashArray"
      stroke-opacity="@Model.Style.StrokeOpacity"
      stroke-width="@Model.Style.StrokeWidth"
      transform="@Model.SvgTransform">
    @Model.Content
</text>

@code {
    [Parameter]
    public Text Model { get; set; }
}
