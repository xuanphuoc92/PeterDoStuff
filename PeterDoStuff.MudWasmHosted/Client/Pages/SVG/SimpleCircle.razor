<MudText Class="my-4">Simple Rectangle rotating and moving:</MudText>

<svg width="@boxWidth" height="@boxHeight">
    <rect width="@boxWidth" height="@boxHeight"
        fill-opacity="0"
        stroke="@strokeColor"
        stroke-width="1" />
    <circle
        cx="@xPosition" cy="@yPosition"
        r="@radius"
        fill="@fillColor"
        fill-opacity="0.2"
        stroke="@strokeColor"
        stroke-width="4" />
</svg>

@code {
    private const int size = 50;
    private const int radius = size / 2;
    private const int boxHeight = size * 2;
    private const int boxWidth = boxHeight * 5;
    private const int leftEdge = size;
    private const int rightEdge = boxWidth - size;

    private int xPosition = size;
    private int yPosition = size;
    private bool leftToRight = true;

    public async Task Tick()
    {
        if (xPosition >= rightEdge && leftToRight)
        {
            xPosition = rightEdge;
            leftToRight = !leftToRight;
        }
        else if (xPosition <= leftEdge && !leftToRight)
        {
            xPosition = leftEdge;
            leftToRight = !leftToRight;
        }
        xPosition += leftToRight ? 1 : -1;
        await InvokeAsync(StateHasChanged);
    }

    private string strokeColor => @Colors.DeepPurple.Accent3;
    private string fillColor => @Colors.DeepPurple.Accent3;
}
