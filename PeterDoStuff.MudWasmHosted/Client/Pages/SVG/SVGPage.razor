@page "/svg"
@using PeterDoStuff.Tools.Graphics

<PlaygroundTitle Page="svg"/>

<MudText Class="my-4">
    Model Reference:
    <MudLink Href="https://swharden.com/blog/2021-01-07-blazor-canvas-animated-graphics/">
        Draw Animated Graphics in the Browser with Blazor WebAssembly
    </MudLink>
</MudText>

<MudRadioGroup @bind-Value="canvas">
    @for (int i = 0; i < demos.Length; i++)
    {
        var demo = demos[i];
        <MudRadio Value="@demo" Color="Color.Primary">@demo.Name</MudRadio>
    }
</MudRadioGroup>

<MudDivider Class="my-4" />

<CanvasSvg Canvas="canvas" />

@code {
    Canvas[] demos = [
        new DemoSimpleCircle(),
        new DemoBouncingBalls(),
        new DemoHeartBeat(),
        new DemoGrowingBalls(),
    ];
    Canvas canvas;

    private Timer Timer;
    protected override void OnInitialized()
    {
        base.OnInitialized();

        canvas = demos.Last();

        Timer = new Timer(Tick, null, 0, 10);
    }

    private void Tick(object? _ = null)
    {
        InvokeAsync(canvas.Tick);
        InvokeAsync(StateHasChanged);
    }
}
