@page "/svg"
@using PeterDoStuff.Tools.Graphics

<PlaygroundTitle Page="svg"/>

<MudCheckBox @bind-Value="showAll">Show All</MudCheckBox>

<MudRadioGroup @bind-Value="canvas" Disabled="@showAll">
    @for (int i = 0; i < demos.Length; i++)
    {
        var demo = demos[i];
        <MudRadio Value="@demo" Color="Color.Primary">@demo.Name</MudRadio>
    }
</MudRadioGroup>

<MudDivider Class="my-4" />

@if(showAll)
{
    @for (int i = 0; i < demos.Length; i++)
    {
        var demo = demos[i];
        <CanvasSvg Canvas="demo" />
    }
}
else
{
    <CanvasSvg Canvas="canvas" />
}

@code {
    Canvas[] demos;
    Canvas canvas;
    bool showAll;

    ModelStyler builder = new ModelStyler()
        .SetStroke(Colors.DeepPurple.Accent3, 4, 1)
        .SetFill(Colors.DeepPurple.Accent3, 0.2);

    private Timer Timer;
    protected override void OnInitialized()
    {
        base.OnInitialized();

        demos = [
            new DemoSimpleBall(builder),
            new DemoBouncingBalls(builder),
            new DemoHeartBeat(builder),
            new DemoGrowingBalls(builder),
            new DemoCirclingTimer(builder),
            new DemoBlinkAndFollow(builder),
            new DemoWandering(builder),
            new DemoPath(builder),
            new DemoCurve(builder),
            new DemoTCurve(builder),
            new DemoBouncyTriangle(builder),
        ];

        canvas = demos.Last();

        Timer = new Timer(Tick, null, 0, 10);
    }

    private void Tick(object? _ = null)
    {
        foreach (var demo in demos)
            InvokeAsync(demo.Resolve);
        InvokeAsync(StateHasChanged);
    }
}
