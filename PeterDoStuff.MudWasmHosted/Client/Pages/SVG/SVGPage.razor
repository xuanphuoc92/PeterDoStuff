@page "/svg"
@using PeterDoStuff.Tools.Graphics

<PlaygroundTitle Page="svg"/>

<MudText>
    Inspirations and References:
</MudText>
<MudList>
    <MudListItem>
        <MudLink Href="https://youtu.be/qlfh_rv6khY?si=KA6yOEJZD7lu3JoY" Target="_blank">
            <MudIcon Icon="@Icons.Custom.Brands.YouTube" Size="Size.Medium"></MudIcon>
            A simple procedural animation technique
        </MudLink>
    </MudListItem>
    <MudListItem>
        <MudLink Href="https://swharden.com/blog/2021-01-07-blazor-canvas-animated-graphics/" Target="_blank">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Medium"></MudIcon>
            Draw Animated Graphics in the Browser with Blazor WebAssembly
        </MudLink>
    </MudListItem>
</MudList>

<MudCheckBox @bind-Value="showAll">Gallery</MudCheckBox>

@if(showAll)
{
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBackIos" OnClick="Prev">Prev</MudButton>
    <MudButton EndIcon="@Icons.Material.Filled.ArrowForwardIos" OnClick="Next">Next</MudButton>

    <MudDivider Class="my-4" />

    <MudGrid>
        @for (int i = pageStart; i < Math.Min(pageStart + pageItems, demos.Length); i++)
        {
            var demo = demos[i];
            <MudItem xs="12" md="4">
                <MudText Class="mb-2">@demo.Name</MudText>
                <CanvasSvg Canvas="demo" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudRadioGroup @bind-Value="canvas">
        <MudGrid Spacing="0">
        @for (int i = 0; i < demos.Length; i++)
        {
            var demo = demos[i];
            <MudItem xs="4" md="2">
                <MudRadio Value="@demo" Color="Color.Primary">@demo.Name</MudRadio>
            </MudItem>
        }
        </MudGrid>
    </MudRadioGroup>

    <MudDivider Class="my-4" />

    <CanvasSvg Canvas="canvas" />
}

@code {
    Canvas[] demos;
    Canvas canvas;
    bool showAll;
    int pageStart = 0;
    int pageItems = 6;

    private void Prev()
    {
        if (pageStart <= 0)
            return;
        pageStart -= pageItems;
    }

    private void Next()
    {
        if (pageStart + pageItems >= demos.Length)
            return;
        pageStart += pageItems;
    }

    Style style = new Style()
        .SetStroke(Colors.DeepPurple.Accent3, 4, 1)
        .SetFill(Colors.DeepPurple.Accent3, 0.2);

    private Timer Timer;
    protected override void OnInitialized()
    {
        base.OnInitialized();

        demos = [
            new DemoSimpleBall(style),
            new DemoBouncingBalls(style),
            new DemoHeartBeat(style),
            new DemoGrowingBalls(style),
            new DemoTimer(style),
            new DemoBlinkAndFollow(style),
            new DemoWandering(style),
            new DemoPath(style),
            new DemoCurve(style),
            new DemoTCurve(style),
            new DemoBouncyTriangle(style),
            new DemoArrowPlane(style),
            new DemoChain(style),
            new DemoFollowYourMouse(style),
            new DemoDistanceConstraint(style),
            new DemoChainedConstraint(style),
            new DemoBodyShape(style),
            new DemoSnake(style),
        ];

        canvas = demos.Last();

        Timer = new Timer(Tick, null, 0, 10);
    }

    private void Tick(object? _ = null)
    {
        if (showAll)
            foreach (var demo in demos)
                InvokeAsync(() => demo.Resolve());
        else
            InvokeAsync(() => canvas.Resolve());
        InvokeAsync(StateHasChanged);
    }
}
