@page "/svg"
@using PeterDoStuff.Tools.Animations

<PlaygroundTitle Page="svg"/>

<SimpleCircle @ref="simpleCircle" />

<CanvasSvg Canvas="canvas" Width="500" Height="100" />

@code {
    SimpleCircle simpleCircle;
    Canvas canvas = new(500, 100);

    private Timer Timer;
    protected override void OnInitialized()
    {
        base.OnInitialized();

        Model.DEFAULT_STROKE_COLOR = Colors.DeepPurple.Accent3;
        Model.DEFAULT_STROKE_WIDTH = 4;

        var circle = new Circle(25) { X = 50, Y = 50 };
        circle.SetAnimation(new PingPongX<Circle>(50, 450));
        canvas.AddModel(circle);

        Timer = new Timer(Tick, null, 0, 10);
    }

    private void Tick(object? _ = null)
    {
        InvokeAsync(simpleCircle.Tick);
        InvokeAsync(canvas.Tick);
        InvokeAsync(StateHasChanged);
    }
}
