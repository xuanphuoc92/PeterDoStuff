@using PeterDoStuff.Tools.Graphics
@if (Model is Rectangle rectangle)
{
    <RectangleSvg Model="@rectangle" />
}
@if (Model is Circle circle)
{
    <CircleSvg Model="@circle" />
}
@if (Model is Text text)
{
    <TextSvg Model="@text" />
}
@if (Model is Line line)
{
    <LineSvg Model="@line" />
}
@if (Model is PathModel path)
{
    <PathSvg Model="@path" />
}
@if (Model is Polygon polygon)
{
    <PolygonSvg Model="polygon" />
}

@code {
    [Parameter]
    public Model Model { get; set; }
}
