@using PeterDoStuff.Extensions
@using PeterDoStuff.Tools.Graphics

<path d="@D"
      stroke="@Model.StrokeColor"
      stroke-opacity="@Model.StrokeOpacity"
      stroke-width="@Model.ScaledStrokeWidth"
      fill="@Model.FillColor"
      fill-opacity="@Model.FillOpacity"/>

@code {
    [Parameter]
    public PathModel Model { get; set; }

    private string D
    {
        get
        {
            var d = "";
            foreach (var command in Model.Commands)
            {
                var commadLine = command.Command + " " + command.Params.Select(p => $"{p.X} {p.Y}").Join(" ");
                var point = command.Point;
                d += $"{commadLine} {point.X} {point.Y} ";
            }
            return d;
        }
    }
}
