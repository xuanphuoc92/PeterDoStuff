@page "/security"
@inject HttpClient Http
@using PeterDoStuff.Extensions
@using PeterDoStuff.MudWasmHosted.Client.Extensions
@using System.Dynamic
@using PeterDoStuff.MudWasmHosted.Shared

<PageTitle>Security</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Size="Size.Large" Icon="@Icons.Material.Filled.Security" />
    Security
</MudText>
<MudText Class="mb-8">This page demonstrates the basic security functions.</MudText>
<MudText Class="mb-8">
    Take note that System.Security.Cryptography APIs (with a few exceptions) may not be supported on Blazor WASM and will cause Runtime Error if attempted to call on WASM (but not on Server):
    <br />
    <MudLink Href="https://learn.microsoft.com/en-us/dotnet/core/compatibility/cryptography/5.0/cryptography-apis-not-supported-on-blazor-webassembly" Target="_blank">
        Breaking change: System.Security.Cryptography APIs not supported on Blazor WebAssembly
    </MudLink>
    <br />
    <MudLink Href="https://github.com/dotnet/runtime/issues/82472">
        .NET 7 WebAssembly - Algorithm 'Aes' is not supported on this platform.
    </MudLink>
    <br />
    Therefore, some of the functions below will be executed on Server.
</MudText>

<MudText Typo="Typo.h4">Byte Array Format</MudText>
<MudToolBar Class="mb-8 d-flex">
    <MudText Color="Color.Info">Hex</MudText>
    <MudSwitch Class="ml-8" @bind-Value="@isBase64Format" UnCheckedColor="Color.Info" Color="Color.Success" />
    <MudText Color="Color.Success">Base64</MudText>
</MudToolBar>

<MudText Class="mb-8" Typo="Typo.h4" Color="Color.Primary">
    Input
</MudText>

<MudGrid Spacing="1" Class="mb-8">
    <MudItem xs="12" md="6">
        <MudTextField T="string" Label="Input String" Variant="Variant.Outlined" AutoGrow Lines="1"
            @bind-Value="inputString" />
    </MudItem>
    <MudItem xs="12" md="6">
        <ByteArrayTextField IsBase64Format="@isBase64Format" Disabled="true" Value="@inputByteArray" Label="Byte Array form (UTF8)" />
    </MudItem>
</MudGrid>

<MudMessageBox @ref="inputBox" Title="Input" YesText="Close">
    <MessageContent>
        <MudTextField T="string" Label="Input String" Variant="Variant.Outlined" AutoGrow Lines="1" Style="width: 360px"
                    @bind-Value="inputString" />
    </MessageContent>
</MudMessageBox>

<MudText Typo="Typo.h4">
    Hashing: SHA
</MudText>
<MudText Class="mb-8">
    SHA Hashing
    <br />
    Externally cross-checed with: <MudLink Target="_blank" Href="https://coding.tools/sha256">Coding.tools</MudLink>
</MudText>

<MudGrid Spacing="1" Class="align-center mb-8">
    <MudItem xs="1" md="1">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenInput">Input</MudButton>
    </MudItem>
    <MudItem xs="3" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="10">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ToSHA256">Hash SHA256</MudButton>
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="outputSHA256" />
    </MudItem>

    <MudItem xs="4" md="2" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="10">
         <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ToSHA512">Hash SHA512</MudButton>
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="outputSHA512" />
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h4">
    Hashing: Argon2id
</MudText>
<MudText Class="mb-8">
    Argon2id Hashing
    <br />
    Externally cross-checed with: <MudLink Target="_blank" Href="https://argon2.online/">Argon2.online</MudLink>
</MudText>

<MudGrid Spacing="1" Class="align-center mb-8">
    <MudItem xs="1" md="1">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenInput">Input</MudButton>
    </MudItem>
    <MudItem xs="3" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
    </MudItem>
    <MudItem xs="8" md="3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateArgon2idSalt">Generate Random Salt</MudButton>
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="argon2idSalt" />
    </MudItem>
    <MudItem xs="4" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="6">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HashArgon2idServer">Hash</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HashArgon2idQuick">Hash (Quick)</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="HashArgon2idClient">Hash at Client (FREEZE)</MudButton> *@
        @if (argon2idHashTime != null)
        {
            <br />
            <MudText Typo="Typo.caption">@argon2idHashTime</MudText>
        }
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="argon2idHash" />
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h4">
    Encryption: AES
</MudText>
<MudText Class="mb-8">
    AES Encrypting and Decrypting with CBC Cipher Mode and PKCS7 Paddding.
    <br/>
    IMPORTANT: Since I have not found any external cross-check that returns the identical results, the implementation may have a slight difference in implementations than the cross-checked sources.
</MudText>

<MudGrid Spacing="1" Class="align-center mb-8">
    <MudItem xs="1" md="1">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenInput">Input</MudButton>
    </MudItem>
    <MudItem xs="3" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
    </MudItem>
    <MudItem xs="8" md="10">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesKey256">Generate Random AES Key (256 bit)</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesKey128">Generate Random AES Key (128 bit)</MudButton>
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="aesKey" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesIV">Generate Random AES IV</MudButton>
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="aesIV" />
    </MudItem>
    <MudItem xs="4" md="2" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="5">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EncryptAesServer">Encrypt</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="EncryptAesClient">Encrypt at client</MudButton> *@
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="aesEncrypted" />
    </MudItem>
    <MudItem xs="5" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="7" md="4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DecryptAesServer">Decrypt</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DecryptAesClient">Decrypt at client</MudButton> *@
        <MudTextField T="string" Variant="Variant.Outlined" AutoGrow Lines="1"
            @bind-Value="aesDecrypted" />
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h4">
    Encryption and Signing/Hashing: RSA
</MudText>
<MudText Class="mb-8">
    RSA Encrypting and Decrypting plaground with 2048 bits key and PKCS1 Padding
    <br/>
    Externally cross-checed with: <MudLink Target="_blank" Href="https://devtoolcafe.com/tools/rsa">DevToolCafe.com</MudLink>
    <br/>
    RSA Signing and Verifying with PKCS1 Padding and SHA512 Hashing
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateRsaKeysServer">
    Generate Random RSA Keys
</MudButton>
@* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="GenerateRsaKeysClient">
    Generate RSA Keys at Client
</MudButton> *@
<MudGrid Spacing="1" Class="align-top mb-8">
    <MudItem xs="12" md="4">
        <MudText Color="Color.Success">Public</MudText>
        <MudTextField T="string" Variant="Variant.Outlined" AutoGrow Lines="1" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Key"
            @bind-Value="rsaPublic" Label="Public Key" AdornmentColor="Color.Success" />
    </MudItem>
    <MudItem xs="12" md="8">
        <MudText Color="Color.Warning">Private</MudText>
        <MudTextField T="string" Variant="Variant.Outlined" AutoGrow Lines="1" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Key"
            @bind-Value="rsaPrivate" Label="Private Key" AdornmentColor="Color.Warning" />
    </MudItem>
</MudGrid>

<MudGrid Spacing="1" Class="align-top mb-8">
    <MudItem xs="1" md="1">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenInput">Input</MudButton>
    </MudItem>
    <MudItem xs="3" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
        <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Success"/>
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="5">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EncryptRsaServer">Encrypt</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="EncryptRsaClient">Encrypt at Client</MudButton> *@
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="rsaEncrypted" />
    </MudItem>
    <MudItem xs="5" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
        <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning" />
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="7" md="4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DecryptRsaServer">Decrypt</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DecryptRsaClient">Decrypt at Client</MudButton> *@
        <MudTextField T="string" Variant="Variant.Outlined" AutoGrow Lines="1"
            @bind-Value="rsaDecrypted" />
    </MudItem>

    <MudItem xs="1" md="1">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenInput">Input</MudButton>
    </MudItem>
    <MudItem xs="3" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
        <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning" />
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="8" md="5">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SignRsaServer">Sign</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="SignRsaClient">Sign at Client</MudButton> *@
        <ByteArrayTextField IsBase64Format="@isBase64Format" @bind-Value="rsaHash" />
    </MudItem>

    <MudItem xs="5" md="1" Class="d-flex justify-end">
        <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
        <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Success" />
        <MudIcon Icon="@Icons.Material.Filled.DoubleArrow" />
    </MudItem>
    <MudItem xs="7" md="4">
        <MudButton Variant="Variant.Filled" Color="@rsaVerifyColor" OnClick="VerifyRsaServer">Verify</MudButton>
        @* <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="VerifyRsaClient">Verify at Client</MudButton> *@
        @* <br/>
        <MudIcon 
            Icon="@(rsaVerified ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
            Color="@(rsaVerified ? Color.Success : Color.Error)" /> *@
    </MudItem>
</MudGrid>

<MudMessageBox @ref="errorBox" YesText="Close"> 
    <MessageContent>
        <MudText Typo="Typo.h5" Color="Color.Error">Error</MudText>
        <MudText Color="Color.Error">@errorMessage</MudText>
    </MessageContent>
</MudMessageBox>

 @code {
    private MudMessageBox errorBox;
    private string errorMessage;
    private async Task ShowError(string errorMessage)
    {
        this.errorMessage = errorMessage;
        await errorBox.Show();
    }

    private MudMessageBox inputBox;
    private async Task OpenInput()
    {
        await inputBox.Show();
    }

    private bool isBase64Format = false;

    private string inputString = "Hello";
    private byte[] inputByteArray => inputString.ToByteArray();

    private byte[]? outputSHA256;
    private void ToSHA256()
    {
        outputSHA256 = inputString
            .ToByteArray()
            .ToSHA256();
    }

    private byte[]? outputSHA512;
    private void ToSHA512()
    {
        outputSHA512 = inputString
            .ToByteArray()
            .ToSHA512();
    }

    private byte[]? argon2idSalt, argon2idHash;
    private string? argon2idHashTime;
    private void GenerateArgon2idSalt()
    {
        argon2idSalt = SecurityExtensions.GenerateSalt();
    }
    private void HashArgon2idClient() // will throw error and freeze
    {
        argon2idHash = inputString
            .ToByteArray()
            .HashArgon2id(argon2idSalt);            
    }
    private async Task HashArgon2idServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/HashArgon2id")
            .SetParam("input", inputString)
            .SetParam("salt", argon2idSalt?.ToHexString())
            .SendAsync<byte[]>();
        argon2idHash = result.Result;
        if (result.Failure)
            await ShowError(result.Error);
        argon2idHashTime = result.ElapsedMilliseconds != null
            ? $"{result.ElapsedMilliseconds} ms"
            : null;
    }
    private async Task HashArgon2idQuick()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/HashArgon2idQuick")
            .SetParam("input", inputString)
            .SetParam("salt", argon2idSalt?.ToHexString())
            .SendAsync<byte[]>();
        argon2idHash = result.Result;
        if (result.Failure)
            await ShowError(result.Error);
        argon2idHashTime = result.ElapsedMilliseconds != null
            ? $"{result.ElapsedMilliseconds} ms"
            : null;
    }

    private byte[]? aesKey;

    private void GenerateAesKey256() => GenerateAesKey(256);
    private void GenerateAesKey128() => GenerateAesKey(128);

    private void GenerateAesKey(int keySize)
    {
        aesKey = SecurityExtensions.GenerateAesKey(keySize);
    }

    private byte[]? aesIV;
    private void GenerateAesIV()
    {
        aesIV = SecurityExtensions.GenerateAesIV();
    }

    private byte[]? aesEncrypted;
    private async Task EncryptAesServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/EncryptAes")
            .SetParam("input", inputString)
            .SetParam("key", aesKey?.ToHexString())
            .SetParam("iv", aesIV?.ToHexString())
            .SendAsync<byte[]>();
        aesEncrypted = result.Result;
        if (result.Failure)
            await ShowError(result.Error);
    }
    private void EncryptAesClient()
    {
        aesEncrypted = inputString
            .EncryptAES(aesKey, aesIV);
    }

    private string? aesDecrypted;
    private async Task DecryptAesServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/DecryptAes")
            .SetParam("input", aesEncrypted?.ToHexString())
            .SetParam("key", aesKey?.ToHexString())
            .SetParam("iv", aesIV?.ToHexString())
            .SendAsync();
        aesDecrypted = result.Result;
        if (result.Failure)
            await ShowError(result.Error);
    }
    private void DecryptAesClient()
    {
        aesDecrypted = aesEncrypted?
            .DecryptAES(aesKey, aesIV);
    }

    private string rsaPublic, rsaPrivate, rsaDecrypted;
    private byte[] rsaEncrypted;

    private async Task GenerateRsaKeysServer()
    {
        var response = await Http
            .Request(HttpMethod.Get, "api/security/GenerateRsaKeys")
            .SendAsync<RsaKeys>();

        rsaPublic = response.Result.Public;
        rsaPrivate = response.Result.Private;
        if (response.Failure)
            await ShowError(response.Error);
    }

    private void GenerateRsaKeysClient()
    {
        (rsaPublic, rsaPrivate) = SecurityExtensions.GenerateRSAKeys();
    }

    private async Task EncryptRsaServer()
    {
        var response = await Http
            .Request(HttpMethod.Post, "api/security/EncryptRsa")
            .SetParam("input", inputString)
            .SetBody(rsaPublic)
            .SendAsync<byte[]>();
        rsaEncrypted = response.Result;
        if (response.Failure)
            await ShowError(response.Error);
    }

    private void EncryptRsaClient()
    {
        rsaEncrypted = inputString
            .ToByteArray()
            .EncryptRSA(rsaPublic);
    }

    private async Task DecryptRsaServer()
    {
        var response = await Http
            .Request(HttpMethod.Post, "api/security/DecryptRsa")
            .SetParam("input", rsaEncrypted?.ToHexString())
            .SetBody(rsaPrivate)
            .SendAsync();
        rsaDecrypted = response.Result;
        if (response.Failure)
            await ShowError(response.Error);
    }

    private void DecryptRsaClient()
    {
        rsaDecrypted = rsaEncrypted
            .DecryptRSA(rsaPrivate)
            .ToUTF8String();
    }

    private byte[] rsaHash;
    private async Task SignRsaServer()
    {
        var response = await Http
            .Request(HttpMethod.Post, "api/security/SignRsa")
            .SetParam("input", inputString)
            .SetBody(rsaPrivate)
            .SendAsync<byte[]>();
        rsaHash = response.Result;
        if (response.Failure)
            await ShowError(response.Error);
    }
    private void SignRsaClient()
    {
        rsaHash = inputString
            .ToByteArray()
            .SignRSA(rsaPrivate);
    }

    private bool? rsaVerified;
    private async Task VerifyRsaServer()
    {
        var response = await Http
            .Request(HttpMethod.Post, "api/security/VerifyRsa")
            .SetParam("input", inputString)
            .SetParam("hash", rsaHash?.ToHexString())
            .SetBody(rsaPublic)
            .SendAsync<bool>();
        rsaVerified = response.Result;
        if (response.Failure)
            await ShowError(response.Error);
    }
    private void VerifyRsaClient()
    {
        rsaVerified = inputString
            .ToByteArray()
            .VerifyRSA(rsaHash, rsaPublic);
    }
    private Color rsaVerifyColor 
    {
        get
        {
            if (rsaVerified == true)
                return Color.Success;
            if (rsaVerified == false)
                return Color.Error;
            return Color.Default;
        }
    }
}
