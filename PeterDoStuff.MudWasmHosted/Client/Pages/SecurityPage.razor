@page "/security"
@inject HttpClient Http
@using PeterDoStuff.Extensions
@using PeterDoStuff.MudWasmHosted.Client.Extensions
@using System.Dynamic

<PageTitle>Security</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Size="Size.Large" Icon="@Icons.Material.Filled.Security" />
    Security
</MudText>
<MudText Class="mb-8">This page demonstrates the basic security functions.</MudText>
<MudText Class="mb-8">
    Take note that System.Security.Cryptography APIs (with a few exceptions) may not be supported on Blazor WASM and will cause Runtime Error if attempted to call on WASM (but not on Server):
    <br />
    <MudLink Href="https://learn.microsoft.com/en-us/dotnet/core/compatibility/cryptography/5.0/cryptography-apis-not-supported-on-blazor-webassembly" Target="_blank">
        Breaking change: System.Security.Cryptography APIs not supported on Blazor WebAssembly
    </MudLink>
    <br />
    <MudLink Href="https://github.com/dotnet/runtime/issues/82472">
        .NET 7 WebAssembly - Algorithm 'Aes' is not supported on this platform.
    </MudLink>
    <br />
    Therefore, some of the functions below will be wired to SubtleCrypto API as workaround.
</MudText>

<MudTextField T="string" Label="Input String" Variant="Variant.Outlined" Class="mb-8"
    @bind-Value="inputString"/>

<MudText Class="mb-8" Typo="Typo.h4">
    Hashing: Secure Hash Algorithms (SHA)
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ToSHA256">Calculate SHA256</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="SHA256 Hash" @bind-Value="outputSHA256" />

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ToSHA512">Calculate SHA512</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="SHA512 Hash" @bind-Value="outputSHA512" />

<MudText Class="mb-8" Typo="Typo.h4">
    Hashing: Argon2id
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateArgon2idSalt">Generate Random Salt</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="Salt" @bind-Value="argon2idSalt" />

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HashArgon2idServer">Hash at Server</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HashArgon2idQuick">Hash at Server (Quick)</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="HashArgon2idClient" Disabled="true">
    Hash at Client (will throw error and freeze)
</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="Hash" @bind-Value="argon2idHash" />

<MudText Class="mb-8" Typo="Typo.h4">
    Encryption: Advanced Encryption Standard (AES)
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesKey256">Generate Random AES Key (256 bit)</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesKey128">Generate Random AES Key (128 bit)</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="AES Key" @bind-Value="aesKey" />

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAesIV">Generate Random AES IV</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="AES IV" @bind-Value="aesIV" />

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EncryptAesServer">Encrypt at server</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="EncryptAesClient">Encrypt at client (will throw error now)</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="AES Encrypted Value" @bind-Value="aesEncrypted" />

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DecryptAesServer">Decrypt at server</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DecryptAesClient">Decrypt at client (will throw error now)</MudButton>
<MudTextField T="string" Variant="Variant.Outlined" Class="mb-8" AutoGrow Lines="3"
    Label="AES Decrypted Value" @bind-Value="aesDecrypted" />

@code {
    private string inputString = "Hello";

    private string outputSHA256;
    private void ToSHA256()
    {
        outputSHA256 = inputString
            .ToByteArray()
            .ToSHA256()
            .ToHexString();
    }

    private string outputSHA512;
    private void ToSHA512()
    {
        outputSHA512 = inputString
            .ToByteArray()
            .ToSHA512()
            .ToHexString();
    }

    private string argon2idSalt, argon2idHash;
    private void GenerateArgon2idSalt()
    {
        argon2idSalt = SecurityExtensions.GenerateSalt().ToHexString();
    }
    private void HashArgon2idClient() // will throw error and freeze
    {
        argon2idHash = inputString
            .ToByteArray()
            .HashArgon2id(argon2idSalt.ToByteArrayAsHexString())
            .ToHexString();
    }
    private async Task HashArgon2idServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/HashArgon2id")
            .SetParam("input", inputString)
            .SetParam("salt", argon2idSalt)
            .SendAsync<byte[]>();
        argon2idHash = result.Result.ToHexString();
    }
    private async Task HashArgon2idQuick()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/HashArgon2idQuick")
            .SetParam("input", inputString)
            .SetParam("salt", argon2idSalt)
            .SendAsync<byte[]>();
        argon2idHash = result.Result.ToHexString();
    }

    private string aesKey;

    private void GenerateAesKey256() => GenerateAesKey(256);
    private void GenerateAesKey128() => GenerateAesKey(128);

    private void GenerateAesKey(int keySize)
    {
        aesKey = SecurityExtensions.GenerateAesKey(keySize).ToHexString();
    }

    private string aesIV;
    private void GenerateAesIV()
    {
        aesIV = SecurityExtensions.GenerateAesIV().ToHexString();
    }

    private string aesEncrypted;
    private async Task EncryptAesServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/EncryptAes")
            .SetParam("input", inputString)
            .SetParam("key", aesKey)
            .SetParam("iv", aesIV)
            .SendAsync<byte[]>();

        if (result.Success)
            aesEncrypted = result.Result.ToHexString();
        else
        {
            throw new Exception(result.Error);
        }

    }
    private void EncryptAesClient()
    {
        aesEncrypted = inputString
            .EncryptAES(aesKey.ToByteArrayAsHexString(), aesIV.ToByteArrayAsHexString())
            .ToHexString();
    }

    private string aesDecrypted;
    private async Task DecryptAesServer()
    {
        var result = await Http
            .Request(HttpMethod.Get, "api/security/DecryptAes")
            .SetParam("input", aesEncrypted)
            .SetParam("key", aesKey)
            .SetParam("iv", aesIV)
            .SendAsync();

        if (result.Success)
            aesDecrypted = result.Result;
        else
        {
            throw new Exception(result.Error);
        }

    }
    private void DecryptAesClient()
    {
        aesDecrypted = aesEncrypted.ToByteArrayAsHexString()
            .DecryptAES(aesKey.ToByteArrayAsHexString(), aesIV.ToByteArrayAsHexString());
    }
}
