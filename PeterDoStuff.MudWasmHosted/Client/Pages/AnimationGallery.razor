@page "/animationGallery"

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Size="Size.Large" Icon="@Icons.Material.Filled.AutoFixHigh" />
    Animation Gallery
</MudText>

<MudText>This page demonstrates the web animations in the tutorial:</MudText>
<MudLink Href="https://youtu.be/vqXLGX0szIQ?si=SIGmPZo-KbaLe3R6" Target="_blank">
    <MudIcon Icon="@Icons.Custom.Brands.YouTube" Size="Size.Medium"></MudIcon>
    Motion Design for the Web | FREE COURSE
</MudLink>

<MudText Class="mt-8 mb-8" Typo="Typo.h4">Loading Icon</MudText>
<style>
    .sample-loader-container {
        width: 20rem;
        inset: 0;
        display: grid;
        place-content: center;
    }

    .sample-loader {
        width: 4rem;
        height: 4rem;
        border: .4rem solid #756bc5;
        border-left-color: transparent;
        border-right-color: transparent;
        border-radius: 50%;
        animation: 1.5s ease-in-out infinite sample-spinner;
    }

    @@keyframes sample-spinner {
        50% {
            transform: rotate(1turn) scale(1.2);
        }

        100% {
            transform: rotate(2turn) scale(1);
        }
    }
</style>
<div class="sample-loader-container">
    <div class="sample-loader"></div>
</div>

<MudText Class="mt-8 mb-8" Typo="Typo.h4">Loading Text</MudText>
<style>
    svg {
        width: 20rem;
        font-weight: 700;
    }

    svg text {
        font-size: 5rem;
        stroke-width: 2;
    }

    svg text.sample-text-body {
        stroke: white;
        animation: 4s infinite alternate animate-stroke;
    }

    @@keyframes animate-stroke {
        0% {
            fill: transparent;
            stroke: white;
            stroke: 3;
            stroke-dashoffset: 25%; /* 25% starting point of the dash */
            stroke-dasharray: 0 32%; /* 0 dash length, 32% of gap width */
        }

        50% {
            fill: transparent;
            stroke: white;
            stroke: 3;
        }

        80%,
        100% {
            fill: white;
            stroke: transparent;
            stroke: 3;
            stroke-dashoffset: -25%;
            stroke-dasharray: 32% 0;
        }
    }
</style>
<svg viewBox="0 0 400 200">
    <text x="50%" y="50%" dy="0.32rem" text-anchor="middle" class="sample-text-body">
        Graphix
    </text>
</svg>

