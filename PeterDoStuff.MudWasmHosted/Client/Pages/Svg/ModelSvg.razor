@using PeterDoStuff.Graphics
@using PeterDoStuff.Graphics.Models

@if (Model is RectangleModel rectangle)
{
    <RectangleSvg Model="@rectangle" />
}
@if (Model is CircleModel circle)
{
    <CircleSvg Model="@circle" />
}
@if (Model is PolygonModel polygon)
{
    <PolygonSvg Model="@polygon" />
}

@code {
    [Parameter]
    public Model Model { get; set; }  
}
