@page "/"

<PageTitle>Peter Do Stuff - Home</PageTitle>

<MudContainer Class="mt-16 px-8" MaxWidth="MaxWidth.False">
    <MudGrid>
        <MudItem xs="12" sm="12" md="3" >
            <MudImage Width="175" Height="175"
                      Src="images/logo.png"
                      Alt="Logo" 
                Class="border-solid rounded-circle border-8"></MudImage>

            <br />
            <br />
            <MudDivider />
            <MudIconButton Href="https://www.linkedin.com/in/peter-vo-43bb1337/" Icon="@Icons.Custom.Brands.LinkedIn" Target="_blank" />
            <MudIconButton Href="https://github.com/xuanphuoc92" Icon="@Icons.Custom.Brands.GitHub" Target="_blank" />
            <MudIconButton Href="https://petervo92.hashnode.dev/" Icon="@Icons.Material.Filled.Edit" Target="_blank" />
            @* <MudPaper Elevation="2">
            </MudPaper> *@
        </MudItem>
        <MudItem xs="12" sm="12" md="9">
            @* <MudPaper Elevation="2" Class="pa-4"></MudPaper> *@
            <MudText Typo="Typo.h3" GutterBottom="true">
                @* <MudIcon Size="Size.Large" Icon="@Icons.Material.Filled.Home" /> *@
                Peter Do Stuff
            </MudText>
            @* <MudAlert Severity="Severity.Normal" Icon="@Icons.Material.Filled.Star">Welcome to my playground!</MudAlert> *@
            <MudText Typo="Typo.h6" Class="mb-8">
                <MudIcon Icon="@Icons.Material.Filled.Star"/>
                Welcome to my playground! Try out the toolkits, services, demos, and games in this site.
            </MudText>

            @foreach (var item in PlaygroundItem.Items)
            {
                <MudLink Href="@item.Link" Underline="Underline.None">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudText Typo="Typo.h5" GutterBottom="true">
                            <MudIcon Style="font-size:0.75em;" Icon="@item.Icon" />
                            @item.Title
                        </MudText>
                        <MudDivider/>
                        <MudText>
                            @item.Description
                        </MudText>
                    </MudPaper>
                </MudLink>
                <br/>
                <br />
            }

        </MudItem>
    </MudGrid>
</MudContainer>