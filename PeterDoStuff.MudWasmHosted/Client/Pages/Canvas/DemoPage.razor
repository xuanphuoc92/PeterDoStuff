@page "/canvas"

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Size="Size.Large" Icon="@Icons.Custom.Uncategorized.Fish" />
    Canvas
</MudText>

<MudText Class="mb-4">
    <p>This page demonstrates the Canvas implementations.</p>
</MudText>

<MudForm Class="mb-4">
    <MudRadioGroup @bind-Value="DemoSelected">
        <MudRadio Value="@Demo.None" Color="Color.Primary">None</MudRadio>
        <MudRadio Value="@Demo.BallField" Color="Color.Primary">Ball Field</MudRadio>
    </MudRadioGroup>
</MudForm>

@switch (DemoSelected)
{
    @case Demo.BallField:
        <BallFieldDemo />
        break;
    default:
        <MudText>No Demo</MudText>
        break;
}

@code {
    private enum Demo
    {
        None,
        BallField
    }

    private Demo DemoSelected = Demo.None;
}
