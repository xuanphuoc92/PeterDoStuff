@page "/workflow"
@using PeterDoStuff.Extensions

<MudText Typo="Typo.h3" GutterBottom="true">
    <MudIcon Size="Size.Large" Icon="@Icons.Material.Filled.AccountTree" />
    Workflow
</MudText>

<MudText>This page demonstrates the workflow presentation in waterfall model.</MudText>

<style>
    .workflowContainer {
        position: relative;
    }
    .workflowLineSvg {
        position: absolute;
        left: 0;
        top: 0;
        z-index: -1;
    }
</style>
<MudContainer Class="workflowContainer mt-8">
    @foreach (var state in SampleWorkflow.States)
    {
        state.X = stateCursorX; 
        state.Y = stateCursorY;
        string style = $"position: absolute; left: {state.X}px; top: {state.Y}px;";
        <MudPaper Width="@($"{itemWidth}px")" Style="@style">
            <MudList Clickable="true">
                <MudListSubheader Style="@($"height: {itemHeight}px")">
                    <MudText Color="Color.Primary" Typo="Typo.h6">@state.Name</MudText>
                </MudListSubheader>
                @foreach (var evt in state.Events)
                {
                    <MudListItem Style="@($"height: {itemHeight}px")" OnClick="() => ClickOnEvent(evt)">
                        @evt.Name
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward"></MudIcon>
                        @evt.ToStates.Select(s => SampleWorkflow.States[s].Name).Join(", ")
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
        stateCursorX += itemWidth + padding;
        stateCursorY += itemHeight * (1 + state.Events.Count) + padding;
    }
    <svg class="workflowLineSvg" viewBox="0 0 @stateCursorX @stateCursorY" style="width: @(stateCursorX)px; height: @(stateCursorY)px;">
        @foreach (var state in SampleWorkflow.States)
        {
            int startX = state.X + itemWidth;
            foreach (var evt in state.Events)
            {
                int startY = state.Y + itemHeight * (1 + state.Events.IndexOf(evt)) + itemHeight / 2;
                string color = evt.On ? Colors.DeepPurple.Accent3 : Colors.Grey.Lighten5;
                double opacity = evt.On ? 1 : 0.1;
                foreach (var toStateIdx in evt.ToStates)
                {
                    var toState = SampleWorkflow.States[toStateIdx];
                    int endX = toState.X + itemWidth / 2;
                    int endY = toState.Y;
                    string d = (endX > startX)
                        ? $"M {startX} {startY} l {endX - startX} 0 l 0 {endY - startY}"
                        : $"M {startX} {startY} l {backwardSpace} 0 l 0 {endY - startY - backwardSpace} l {endX - startX - backwardSpace} 0 l 0 {backwardSpace}";
                    <path d="@d" fill="none" stroke="@color" stroke-width="0.2rem" stroke-opacity="@opacity"></path>
                }
            }
        }
    </svg>
</MudContainer>

@code {
    private const int itemWidth = 400;
    private const int itemHeight = 50;
    private const int padding = 50;

    private const int backwardSpace = 30;

    private int stateCursorX = 0;
    private int stateCursorY = 0;

    private void ClickOnEvent(Event evt)
    {
        stateCursorX = 0;
        stateCursorY = 0;
        evt.On = !evt.On;
    }

    private Workflow SampleWorkflow = Workflow
            .New("Sample Workflow")
            .StateEvent("Start", "Save as Draft", "Draft")
            .StateEvent("Start", "Submit for Approval", "Pending Approval")
            .StateEvent("Draft", "Submit for Approval", "Pending Approval")
            .StateEvent("Pending Approval", "Approve", "Pending Approval", "Approved")
            .StateEvent("Pending Approval", "Reject", "Rejected")
            .StateEvent("Pending Approval", "Query", "Draft");

    private class Workflow
    {
        public string Name { get; set; }
        public List<State> States { get; set; } = new List<State>();

        public static Workflow New(string name)
        {
            Workflow workflow = new();
            workflow.Name = name;
            return workflow;
        }

        private State GetOrCreate(string stateName)
        {
            State? state = States.SingleOrDefault(s => s.Name == stateName);
            if (state == null)
            {
                state = new();
                state.Name = stateName;
                States.Add(state);
            }
            return state;
        }

        public Workflow StateEvent(string stateName, string eventName, params string[] toStateNames)
        {
            State? state = GetOrCreate(stateName);

            Event? evt = state.Events.SingleOrDefault(e => e.Name == eventName);
            if (evt == null)
            {
                evt = new();
                evt.Name = eventName;
                state.Events.Add(evt);
            }

            foreach (var toStateName in toStateNames)
            {
                var toState = GetOrCreate(toStateName);
                evt.ToStates.Add(States.IndexOf(toState));
            }

            return this;
        }
    }

    private class State
    {
        public string Name { get; set; }
        public List<Event> Events { get; set; } = new List<Event>();
        public int X { get; set; }
        public int Y { get; set; }
    }

    private class Event
    {
        public string Name { get; set; }
        public List<int> ToStates { get; set; } = new List<int>();
        public bool On { get; set; }
    }
}
