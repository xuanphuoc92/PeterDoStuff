@page "/docTemplate"
@using System.Text
@using PeterDoStuff.Extensions
@using static PeterDoStuff.MudWasmHosted.Client.Pages.DocTemplate.DocTemplateController
@inject IJSRuntime JS

<PlaygroundTitle Page="docTemplate" />

@* <iframe srcdoc="@DocTemplateController.SampleHtml" style="width:100%; height:35cm; border:none;"></iframe> *@

<MudButton Variant="Variant.Filled" Color="Color.Primary"
    StartIcon="@Icons.Material.Filled.Download"
    OnClick="DownloadJson">
    Download JSON
</MudButton>

<MudFileUpload T="IBrowserFile" FilesChanged="UploadJson">
    <ButtonTemplate>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.Upload"
            for="@context.Id" HtmlTag="label">
            Upload JSON
        </MudButton>
    </ButtonTemplate>
</MudFileUpload>

<EditForm Model="@model">
    <EntityControl Entity="@model.Person" />
    <MudDivider Class="my-4"/>
    <MudTextField Variant="Variant.Outlined" Label="Location" @bind-Value="model.Location" For="@(() => model.Location)" />
    <MudGrid>
        <MudItem xs="6" sm="2">
            <MudTextField Variant="Variant.Outlined" @bind-Value="model.PhoneLabel" For="@(() => model.PhoneLabel)" />
        </MudItem>
        <MudItem xs="6" sm="10">
            <MudTextField Variant="Variant.Outlined" @bind-Value="model.PhoneNumber" For="@(() => model.PhoneNumber)" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudTextField Variant="Variant.Outlined" @bind-Value="model.FluencyLabel" For="@(() => model.FluencyLabel)" />
        </MudItem>
        <MudItem xs="6" sm="10">
            <MudTextField Variant="Variant.Outlined" @bind-Value="model.Fluency" For="@(() => model.Fluency)" />
        </MudItem>
    </MudGrid>
    <MudTextField Variant="Variant.Outlined" Label="Email" @bind-Value="model.Email" For="@(() => model.Email)" />
    <MudGrid>
        <LinkControl Link="@model.LinkedIn" Icon="@Icons.Custom.Brands.LinkedIn" />
    </MudGrid>
    <MudGrid>
        <LinkControl Link="@model.GitHub" Icon="@Icons.Custom.Brands.GitHub" />
    </MudGrid>
    <MudText Class="mt-4">Other Links</MudText>
    @for(int i = 0; i < model.OtherLinks.Count; i++)
    {
        var otherLink = model.OtherLinks[i];
        <MudGrid>
            <MudItem xs="1">
                <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                    OnClick="() => model.OtherLinks.Remove(otherLink)"></MudIconButton>
            </MudItem>
            <LinkControl LabelWidth="1" Link="@otherLink" />
        </MudGrid>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCircleOutline"
        OnClick="() => model.OtherLinks.Add(new())">Link</MudButton>
    <MudTextField Variant="Variant.Outlined" Label="AboutMe" 
        Lines="10"
        @bind-Value="model.AboutMe" For="@(() => model.AboutMe)" />
    
    <MudText Class="mt-4">Experiences</MudText>
    @for (int i = 0; i < model.Experiences.Count; i++)
    {
        var experience = model.Experiences[i];
        <MudGrid>
            <MudItem xs="1">
                <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                    OnClick="() => model.Experiences.Remove(experience)"></MudIconButton>
            </MudItem>
            <MudItem xs="11">
                <EntityControl Entity="@experience.Company" />
                @for (int j = 0; j < experience.Items.Count; j++)
                {
                    var item = experience.Items[j];
                    <MudGrid>
                        <MudItem xs="1">
                            <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                                OnClick="() => experience.Items.Remove(item)"></MudIconButton>
                        </MudItem>
                        <MudItem xs="11" sm="5">
                            <MudTextField Variant="Variant.Outlined" Label="Position"
                                @bind-Value="item.Position" For="@(() => item.Position)" />
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudDatePicker Variant="Variant.Outlined" Label="From" @bind-Date="item.From" />
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudDatePicker Variant="Variant.Outlined" Label="To" @bind-Date="item.To" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Variant="Variant.Outlined" Label="Description"
                                Lines="5"
                                @bind-Value="item.Description" For="@(() => item.Description)" />
                        </MudItem>
                    </MudGrid>
                }
                <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCircleOutline"
                    OnClick="() => experience.Items.Add(new())"></MudButton>
            </MudItem>
        </MudGrid>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddCircleOutline" 
        OnClick="() => model.Experiences.Add(new())">Experience</MudButton>
</EditForm>

@code {
    private Resume model = new();

    private async Task DownloadJson()
    {
        string fileName = (model.Person.Name ?? "") + " Profile.json";
        using MemoryStream csvFileStream = new MemoryStream(
            Encoding.UTF8.GetBytes(model.ToJson(beautify: true)));
        using var streamRef = new DotNetStreamReference(stream: csvFileStream);
        await JS.InvokeVoidAsync("downloadFileFromStream", fileName.Trim(), streamRef);
    }

    private async Task UploadJson(IBrowserFile file)
    {
        using MemoryStream inputFileStream = new MemoryStream();
        await file.OpenReadStream(file.Size).CopyToAsync(inputFileStream);
        inputFileStream.Position = 0;
        using StreamReader reader = new StreamReader(inputFileStream, Encoding.UTF8);
        string json = reader.ReadToEnd();
        model = json.FromJson<Resume>();
    }
}
