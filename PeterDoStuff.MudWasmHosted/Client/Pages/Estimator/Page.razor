@page "/estimator"
@using PeterDoStuff.MudWasmHosted.Client.Extensions
@using static PeterDoStuff.MudWasmHosted.Client.Pages.Estimator.Controller

<PlaygroundTitle Page="estimator" />

<EditForm Model="@Project">
    <MudGrid>
        <MudItem xs="12">
            <MudTextField Label="Project Name" Variant="Variant.Outlined" @bind-Value="Project.Name" For="@(() => Project.Name)"></MudTextField>
        </MudItem>
        @for (int i = 0; i < Project.Groups.Count; i++)
        {
            var group = Project.Groups[i];
            <MudItem xs="12" md="2">
                <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                               OnClick="() => Project.Groups.Remove(group)"></MudIconButton>
                <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.ArrowCircleUp"
                               OnClick="() => Project.Groups.MoveUp(group)"></MudIconButton>
                <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.ArrowCircleDown"
                               OnClick="() => Project.Groups.MoveDown(group)"></MudIconButton>
            </MudItem>
            <MudItem xs="12" md="10">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField Label="Group Name" Variant="Variant.Outlined" @bind-Value="group.Name" For="@(() => group.Name)"></MudTextField>
                    </MudItem>
                    @for (int j = 0; j < group.Tasks.Count; j++)
                    {
                        var task = group.Tasks[j];
                        <MudItem xs="6" md="3">
                            <MudIconButton Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                                           OnClick="() => group.Tasks.Remove(task)"></MudIconButton>
                            <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.ArrowCircleUp"
                                           OnClick="() => group.Tasks.MoveUp(task)"></MudIconButton>
                            <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.ArrowCircleDown"
                                           OnClick="() => group.Tasks.MoveDown(task)"></MudIconButton>
                        </MudItem>
                        <MudItem xs="6" md="9">
                            <MudTextField Label="Task Description" Lines="3" Variant="Variant.Outlined" @bind-Value="task.Description" For="@(() => task.Description)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect Variant="Variant.Outlined" @bind-Value="task.EstimateType">
                                @for (int k = 0; k < EstimateTypes.Length; k++)
                                {
                                    var value = EstimateTypes[k];
                                    var text = value.ToString();
                                    <MudSelectItem Value="value">
                                        <MudText>@text</MudText>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (task.EstimateType == EstimateType.Fixed)
                        {
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="task.FixedEstimate.Value" Label="Value" Variant="Variant.Outlined" Step=".5M" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField @bind-Value="task.FixedEstimate.Error" Label="Error" Variant="Variant.Outlined" Step=".1M" />
                            </MudItem>
                        }
                        @if (task.EstimateType == EstimateType.ThreePoint)
                        {
                            <MudItem xs="4">
                                <MudNumericField @bind-Value="task.ThreePointEstimate.Best" Label="Best (a)" Variant="Variant.Outlined" Step=".5M" />
                            </MudItem>
                            <MudItem xs="4">
                                <MudNumericField @bind-Value="task.ThreePointEstimate.Likely" Label="Likely (m)" Variant="Variant.Outlined" Step=".5M" />
                            </MudItem>
                            <MudItem xs="4">
                                <MudNumericField @bind-Value="task.ThreePointEstimate.Worst" Label="Worst (b)" Variant="Variant.Outlined" Step=".5M" />
                            </MudItem>
                        }
                    }
                    <MudItem xs="12">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="() => group.Tasks.Add(new(group.Tasks.Count + 1))">Task</MudButton>
                    </MudItem>
                </MudGrid>
            </MudItem>
        }
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="() => Project.Groups.Add(new(Project.Groups.Count + 1))">Group</MudButton>
        </MudItem>
    </MudGrid>    
</EditForm>



@code {
    private Project Project = new();

    private readonly EstimateType[] EstimateTypes = Enum.GetValues(typeof(EstimateType)).Cast<EstimateType>().ToArray();
}
